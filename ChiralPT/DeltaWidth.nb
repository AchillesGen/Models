Cell[BoxData[
 RowBox[{"trace", "=", 
  RowBox[{
   RowBox[{"DiracTrace", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"GS", "[", "pn", "]"}], "+", "Mn"}], ")"}], ".", 
     RowBox[{"GA", "[", "beta1", "]"}], ".", "GA5", ".", 
     RowBox[{"(", 
      RowBox[{"-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"GS", "[", "pd", "]"}], "+", "M"}], ")"}], ".", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"MT", "[", 
           RowBox[{"mu1", ",", "mu2"}], "]"}], "-", 
          RowBox[{
           RowBox[{"1", "/", "3"}], 
           RowBox[{
            RowBox[{"GA", "[", "mu1", "]"}], ".", 
            RowBox[{"GA", "[", "mu2", "]"}]}]}], "-", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"3", "M"}], ")"}]}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"FV", "[", 
               RowBox[{"pd", ",", "mu1"}], "]"}], 
              RowBox[{"GA", "[", "mu2", "]"}]}], "-", 
             RowBox[{
              RowBox[{"GA", "[", "mu1", "]"}], 
              RowBox[{"FV", "[", 
               RowBox[{"pd", ",", "mu2"}], "]"}]}]}], ")"}]}], "-", 
          RowBox[{
           RowBox[{"2", "/", 
            RowBox[{"(", 
             RowBox[{"3", 
              RowBox[{"M", "^", "2"}]}], ")"}]}], 
           RowBox[{"FV", "[", 
            RowBox[{"pd", ",", "mu1"}], "]"}], 
           RowBox[{"FV", "[", 
            RowBox[{"pd", ",", "mu2"}], "]"}]}]}], ")"}]}]}], ")"}], ".", 
     RowBox[{"GA", "[", "beta2", "]"}], ".", "GA5"}], "]"}], "//", 
   "DiracSimplify"}]}]], "Input",
 CellChangeTimes->{{3.985349312742577*^9, 3.9853493235244102`*^9}, {
