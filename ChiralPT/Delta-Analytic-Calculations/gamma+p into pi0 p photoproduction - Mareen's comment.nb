       SubscriptBox["p", "com"], "2"]}]]}], TraditionalForm]],ExpressionUUID->
  "e9779c3f-0c54-b641-9dca-4c449baea7b9"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["d\[Sigma]", 
     RowBox[{"dCos", "[", "\[Theta]", "]"}]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"|", "\[ScriptCapitalM]", 
       SuperscriptBox["|", "2"]}], 
      RowBox[{"32", " ", "\[Pi]", " ", "s"}]], 
     FractionBox[
      SubscriptBox["p", "f"], 
      SubscriptBox["p", "i"]]}]}], TraditionalForm]],ExpressionUUID->
  "94b922c4-7c46-cd4b-bbfb-5e4c81181da4"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["d\[Sigma]", "d\[CapitalOmega]"], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"|", "\[ScriptCapitalM]", 
       SuperscriptBox["|", "2"]}], 
      RowBox[{"64", " ", 
       SuperscriptBox["\[Pi]", "2"], " ", "s"}]], 
     FractionBox[
      SubscriptBox["p", "f"], 
      SubscriptBox["p", "i"]]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1b812948-2ad7-dd4c-90f3-f72f3238dc72"],
 "."
}], "Text",
