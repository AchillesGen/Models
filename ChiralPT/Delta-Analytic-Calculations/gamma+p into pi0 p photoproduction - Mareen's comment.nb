Cell[BoxData[{
 RowBox[{
  RowBox[{"pBefore", "=", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], "-", 
      RowBox[{"2", "s", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          SubscriptBox["m", "1"], "2"], "+", 
         SuperscriptBox[
          SubscriptBox["m", "2"], "2"]}], ")"}]}], "+", 
