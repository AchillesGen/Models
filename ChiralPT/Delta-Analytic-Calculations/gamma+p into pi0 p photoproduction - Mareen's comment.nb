          SubscriptBox["m", "2"], "2"]}], ")"}], "2"]}], 
     RowBox[{"4", "s"}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pAfter", "=", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], "-", 
