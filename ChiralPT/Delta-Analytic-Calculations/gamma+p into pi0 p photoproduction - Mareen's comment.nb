  FormBox[
   RowBox[{
    FractionBox["d\[Sigma]", 
     RowBox[{"dCos", "[", "\[Theta]", "]"}]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"|", "\[ScriptCapitalM]", 
       SuperscriptBox["|", "2"]}], 
      RowBox[{"32", " ", "\[Pi]", " ", "s"}]], 
     FractionBox[
