Cell[TextData[{
 "The Mandelstam variable t is very nice for elastic scattering. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[Element]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "4"}], 
       SuperscriptBox[
        SubscriptBox["p", "com"], "2"]}], ",", "0"}]}]}], TraditionalForm]],
  ExpressionUUID->"027a3c9b-1951-ae41-8d0d-bdd12247c90c"],
 ") where"
}], "Text",
 CellChangeTimes->{{3.978096677073334*^9, 3.9780967215854855`*^9}, {
  3.9780968868767204`*^9, 
