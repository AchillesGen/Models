Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"pionNucleonDeltaGI", "[", 
     RowBox[{"p2_", ",", "p3_", ",", "mu2_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "}"}], ",", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       FractionBox["gDGI", 
        RowBox[{"fPi", " ", "M"}]], "*", 
       SqrtBox[
        FractionBox["2", "3"]], "*", 
       RowBox[{"Eps", "[", 
        RowBox[{
         RowBox[{"LorentzIndex", "[", "mu2", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Alpha]", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Beta]", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Gamma]", "]"}]}], "]"}], 
       RowBox[{
        RowBox[{"GA", "[", "\[Alpha]", "]"}], ".", 
        RowBox[{"GA", "[", "5", "]"}]}], 
       RowBox[{"Pair", "[", 
        RowBox[{
         RowBox[{"Momentum", "[", "p3", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Beta]", "]"}]}], "]"}], 
       RowBox[{"Pair", "[", 
        RowBox[{
         RowBox[{"Momentum", "[", "p2", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Gamma]", "]"}]}], "]"}]}]}], "]"}]}],
    ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"index", " ", "3"}], " ", "==", " ", "pion"}], ";", " ", 
     RowBox[{
      RowBox[{"index", " ", "1"}], " ", "==", " ", "Nucleon"}]}], ",", " ", 
    RowBox[{"isospinFactor", "=", 
     SqrtBox[
      FractionBox["2", "3"]]}], ",", " ", 
    RowBox[{
     RowBox[{"the", " ", "gDGI"}], " ", "=", " ", 
     RowBox[{"h", " ", "from", " ", "the", " ", "paper"}]}]}], " ", 
   "*)"}]}]], "Input",
