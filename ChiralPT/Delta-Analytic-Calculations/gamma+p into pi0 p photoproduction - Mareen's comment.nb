bf63d5db2011"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pCOM", "[", 
    RowBox[{"s_", ",", "m1_", ",", "m2_"}], "]"}], ":=", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], "-", 
      RowBox[{"2", "s", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["m1", "2"], "+", 
         SuperscriptBox["m2", "2"]}], ")"}]}], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["m1", "2"], "-", 
         SuperscriptBox["m2", "2"]}], ")"}], "2"]}], 
     RowBox[{"4", "s"}]]]}], ";"}]], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"9185b7ea-bb76-9646-922b-2a0b703c8f9e"],

