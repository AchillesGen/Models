       RowBox[{
        RowBox[{"LorentzIndex", "[", "\[Mu]", "]"}], ",", 
        RowBox[{"LorentzIndex", "[", "\[Nu]", "]"}]}], "]"}], "-", 
      RowBox[{
       FractionBox["1", "3"], 
       RowBox[{
        RowBox[{"GA", "[", "\[Mu]", "]"}], ".", 
        RowBox[{"GA", "[", "\[Nu]", "]"}]}]}], "+", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"3", "M"}]], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
