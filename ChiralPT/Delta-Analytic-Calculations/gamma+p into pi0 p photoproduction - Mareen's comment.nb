  RowBox[{"DeltaPropagator", "[", 
   RowBox[{"p_", ",", "\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
  RowBox[{"-", 
   RowBox[{
    FractionBox[
     RowBox[{
