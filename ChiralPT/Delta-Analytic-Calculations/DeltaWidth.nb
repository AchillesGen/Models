Cell[CellGroupData[{

Cell["Delta Width Calculation", "Section",
 CellChangeTimes->{{3.9853574435371428`*^9, 
  3.985357447213491*^9}},ExpressionUUID->"836615a4-894a-430d-b9f3-\
288cff737f79"],

Cell[TextData[{
 "The calculation of the width is carried out below. The vertex for \
Delta-nucleon-pion is taken from the FeynRules output and is given as: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Mu]"], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", "h"}], 
      RowBox[{
       SubscriptBox["M", "\[CapitalDelta]"], 
       SubscriptBox["f", "\[Pi]"]}]], 
     SuperscriptBox["\[Epsilon]", "\[Mu]\[Nu]\[Alpha]\[Beta]"], 
     SubscriptBox["p", "\[CapitalDelta]\[Alpha]"], 
     SubscriptBox["p", "\[Pi]\[Nu]"], 
     SubscriptBox["\[Gamma]", "\[Beta]"], 
     SubscriptBox["\[Gamma]", "5"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "661b50aa-a969-4624-9bc9-4cc445ce660e"],
 ". The spin sum is related to the numerator of the propagator according to \
Weinberg\[CloseCurlyQuote]s QFT textbook (Sections 5.5, 5.7, and 6.2, namely \
the (anti)commutator of the fields is related to the completeness relation, \
and the propagator is related to the (anti)commutator of the fields). \n\nIf \
we choose to use the propagator given as Eq. B45 in our draft, we get that \
the completeness relation is:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{
       StyleBox[
        RowBox[{"p", 
         AdjustmentBox["\:29f8",
          
          BoxMargins->{{-0.8258064516129032, 0.8258064516129032}, {0., 
           0.}}]}]], "+", 
       SubscriptBox["M", "\[CapitalDelta]"]}], ")"}]}], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[Eta]", "\[Mu]\[Nu]"], "-", 
      RowBox[{
       FractionBox["1", "3"], 
       SuperscriptBox["\[Gamma]", "mu"], 
       SuperscriptBox["\[Gamma]", "nu"]}], "-", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"3", 
         SubscriptBox["M", "\[CapitalDelta]"]}]], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["p", "\[Mu]"], 
          SuperscriptBox["\[Gamma]", "\[Nu]"]}], "-", 
         RowBox[{
          SuperscriptBox["\[Gamma]", "\[Mu]"], 
          SuperscriptBox["p", "\[Nu]"]}]}], ")"}]}], "-", 
      RowBox[{
       FractionBox["2", 
        RowBox[{"3", 
         SuperscriptBox[
          SubscriptBox["M", "\[CapitalDelta]"], "2"]}]], 
       SuperscriptBox["p", "\[Mu]"], 
       SuperscriptBox["p", "\[Nu]"]}]}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "21f7fda8-ac73-4a9d-a838-c39efd529d2b"],
 ". Combining these together and taking the trace for the setup, we get the \
equations below, which are consistent with the paper. (I will work on \
breaking it up into the individual pieces and attempt to do the \[Gamma]N \
\[Rule] \[Pi]N calculation next)"
}], "Text",
 CellChangeTimes->{{3.9853574697083387`*^9, 3.985357676062344*^9}, {
   3.985357708190444*^9, 3.985357748854987*^9}, {3.985357811747136*^9, 
   3.9853578225741587`*^9}, 3.98538690420864*^9, {3.98538712946453*^9, 
   3.9853872005938663`*^9}, {3.9853873589716377`*^9, 3.98538737285186*^9}, {
   3.9853874935457973`*^9, 3.985387494746921*^9}, {3.985387754861158*^9, 
   3.9853877925177593`*^9}, {3.985387824789112*^9, 3.985388023133192*^9}, {
   3.9853880633698463`*^9, 
   3.985388328508977*^9}},ExpressionUUID->"583d1016-6423-4e2a-ac44-\
8b6c6b28b2b2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"vertex", "[", 
   RowBox[{"mu_", ",", "pd_", ",", "ppi_"}], "]"}], ":=", 
  RowBox[{"FCRenameDummyIndices", "[", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "h"}], 
     RowBox[{"M", " ", "fpi"}]], " ", 
    RowBox[{"LC", "[", 
     RowBox[{"mu", ",", "nu", ",", "alpha", ",", "beta"}], "]"}], 
    RowBox[{"FV", "[", 
     RowBox[{"pd", ",", "alpha"}], "]"}], 
    RowBox[{"FV", "[", 
     RowBox[{"ppi", ",", "nu"}], "]"}], 
    RowBox[{
     RowBox[{"GA", "[", "beta", "]"}], ".", "GA5"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"spinSum", "[", 
   RowBox[{"mu_", ",", "nu_", ",", "pd_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"GS", "[", "pd", "]"}], "+", "M"}], ")"}], ".", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"MT", "[", 
      RowBox[{"mu", ",", "nu"}], "]"}], "-", 
     RowBox[{
      RowBox[{"1", "/", "3"}], 
      RowBox[{
       RowBox[{"GA", "[", "mu", "]"}], ".", 
       RowBox[{"GA", "[", "nu", "]"}]}]}], "-", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"3", "M"}], ")"}]}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"FV", "[", 
          RowBox[{"pd", ",", "mu"}], "]"}], 
         RowBox[{"GA", "[", "nu", "]"}]}], "-", 
        RowBox[{
         RowBox[{"GA", "[", "mu", "]"}], 
         RowBox[{"FV", "[", 
          RowBox[{"pd", ",", "nu"}], "]"}]}]}], ")"}]}]}], 
    ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.9853887646686363`*^9, 3.985388772042841*^9}, {
  3.9853888072242393`*^9, 3.985388898804117*^9}, {3.985388946732833*^9, 
  3.985388950272875*^9}, {3.985389011170484*^9, 3.985389024323979*^9}, {
  3.985389256682076*^9, 3.9853892650814257`*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"4191fd99-5bed-48e0-ae69-518c7468a3c3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"pd", ",", "pd"}], "]"}], "=", 
   RowBox[{"M", "^", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"pn", ",", "pn"}], "]"}], "=", 
   RowBox[{"Mn", "^", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"ppi", ",", "ppi"}], "]"}], "=", 
   RowBox[{"Mpi", "^", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"pd", ",", "pn"}], "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"M", "^", "2"}], "+", 
      RowBox[{"Mn", "^", "2"}], "-", 
      RowBox[{"Mpi", "^", "2"}]}], ")"}], "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"pd", ",", "ppi"}], "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"M", "^", "2"}], "+", 
      RowBox[{"Mpi", "^", "2"}], "-", 
      RowBox[{"Mn", "^", "2"}]}], ")"}], "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"ppi", ",", "pn"}], "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"M", "^", "2"}], "-", 
      RowBox[{"Mpi", "^", "2"}], "-", 
      RowBox[{"Mn", "^", "2"}]}], ")"}], "/", "2"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.985389192744647*^9, 3.985389217697878*^9}, 
   3.985389275470891*^9},
 CellLabel->"In[47]:=",ExpressionUUID->"1fbc2d94-b3a7-4538-90ee-6c6ac83ed76e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"amp2", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"DiracTrace", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"GS", "[", "pn", "]"}], "+", "Mn"}], ")"}], ".", 
       RowBox[{"vertex", "[", 
        RowBox[{"mu1", ",", "pd", ",", "ppi"}], "]"}], ".", 
       RowBox[{"spinSum", "[", 
        RowBox[{"mu1", ",", "mu2", ",", "pd"}], "]"}], ".", 
       RowBox[{"vertex", "[", 
        RowBox[{"mu2", ",", "pd", ",", "ppi"}], "]"}]}], "]"}], "//", 
     "DiracSimplify"}], "//", "Simplify"}], "//", "Factor"}]}]], "Input",
 CellChangeTimes->{{3.985389030430769*^9, 3.985389071864924*^9}, {
  3.9853891292207823`*^9, 3.9853891816884117`*^9}, {3.985389222983642*^9, 
  3.985389244689349*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"0c3067d6-f9a7-47e0-b482-3182ff342828"],

Cell[BoxData[
 FormBox[
  FractionBox[
   RowBox[{
    SuperscriptBox["h", "2"], " ", 
    RowBox[{"(", 
     RowBox[{"M", "-", "Mn", "-", "Mpi"}], ")"}], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"M", "+", "Mn", "-", "Mpi"}], ")"}], "2"], " ", 
    RowBox[{"(", 
     RowBox[{"M", "-", "Mn", "+", "Mpi"}], ")"}], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"M", "+", "Mn", "+", "Mpi"}], ")"}], "2"]}], 
   RowBox[{"3", " ", 
    SuperscriptBox["fpi", "2"], " ", 
    SuperscriptBox["M", "2"]}]], TraditionalForm]], "Output",
 CellChangeTimes->{{3.98538914940586*^9, 3.985389277629499*^9}},
 CellLabel->"Out[53]=",ExpressionUUID->"cdbe0d9c-c6e5-40f9-b3ea-d2ad46981ed1"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"pCom", "[", 
   RowBox[{"m1_", ",", "m2_", ",", "m3_"}], "]"}], ":=", 
  FractionBox[
   SqrtBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{"m1", "+", "m2", "+", "m3"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"m1", "+", "m2", "-", "m3"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"m1", "-", "m2", "+", "m3"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"m1", "-", "m2", "-", "m3"}], ")"}]}]], 
   RowBox[{"2", "m1"}]]}]], "Input",
 CellChangeTimes->{{3.985350041360867*^9, 3.9853500518929996`*^9}, 
   3.9853501097924623`*^9},
 CellLabel->"In[54]:=",ExpressionUUID->"44da0247-514f-4d31-a22d-e11157734639"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"decayWidth", "=", 
  RowBox[{
   FractionBox[
    RowBox[{"4", "\[Pi]", " ", "amp2", " ", 
     RowBox[{"pCom", "[", 
      RowBox[{"M", ",", "Mn", ",", "Mpi"}], "]"}]}], 
    RowBox[{"32", 
     SuperscriptBox["\[Pi]", "2"], 
     SuperscriptBox["M", "2"]}]], "//", "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.985349979631377*^9, 3.9853500364287252`*^9}, {
  3.9853501242693872`*^9, 3.985350126421702*^9}},
 CellLabel->"In[55]:=",ExpressionUUID->"b84101b5-ed06-4c90-b96a-90b691525db4"],

Cell[BoxData[
 FormBox[
  FractionBox[
   RowBox[{
    SuperscriptBox["h", "2"], " ", 
    RowBox[{"(", 
     RowBox[{"M", "+", "Mn", "-", "Mpi"}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"M", "+", "Mn", "+", "Mpi"}], ")"}], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"M", "-", "Mn", "-", "Mpi"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"M", "+", "Mn", "-", "Mpi"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"M", "-", "Mn", "+", "Mpi"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"M", "+", "Mn", "+", "Mpi"}], ")"}]}], ")"}], 
     RowBox[{"3", "/", "2"}]]}], 
   RowBox[{"48", " ", "\[Pi]", " ", 
    SuperscriptBox["fpi", "2"], " ", 
    SuperscriptBox["M", "5"]}]], TraditionalForm]], "Output",
 CellChangeTimes->{{3.985350112852414*^9, 3.985350127074085*^9}, 
   3.985350205079977*^9, 3.985389300702837*^9},
 CellLabel->"Out[55]=",ExpressionUUID->"2e535a69-79d4-4d90-ba52-dbbbea24b195"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"decayWidthPaper", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox[
       SuperscriptBox["h", "2"], 
       RowBox[{"3", "\[Pi]", " ", 
        SuperscriptBox["fpi", "2"]}]], 
      FractionBox[
       SuperscriptBox[
        RowBox[{"pCom", "[", 
         RowBox[{"M", ",", "Mn", ",", "Mpi"}], "]"}], "3"], "M"], 
      RowBox[{"(", 
       RowBox[{"Mn", "+", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"pCom", "[", 
            RowBox[{"M", ",", "Mn", ",", "Mpi"}], "]"}], "2"], "+", 
          SuperscriptBox["Mn", "2"]}], "]"}]}], ")"}]}], "//", "Expand"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"M", ",", "Mn", ",", "Mpi"}], "}"}], "\[Element]", "Reals"}],
        ",", 
       RowBox[{
        RowBox[{"M", "^", "2"}], ">", 
        RowBox[{
         RowBox[{"Mn", "^", "2"}], "+", 
         RowBox[{"Mpi", "^", "2"}]}]}], ",", 
       RowBox[{"M", ">", "0"}]}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.985350272520831*^9, 3.985350397495275*^9}, {
  3.985350475842813*^9, 3.98535056017868*^9}},
 CellLabel->"In[56]:=",ExpressionUUID->"5c23c1e2-5ee1-4d8a-a0f4-4f4db5bb602d"],

