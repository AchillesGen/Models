Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"decayWidthPaper", "/", "decayWidth"}], "//", "Simplify"}]], "Input",\

 CellChangeTimes->{{3.985350378754044*^9, 3.985350387880725*^9}},
