 FormBox[
  FractionBox[
   RowBox[{
    SuperscriptBox["h", "2"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"M", "+", "Mn", "-", "Mpi"}], ")"}], "2"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"M", "+", "Mn", "+", "Mpi"}], ")"}], "2"], " ", 
    SqrtBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{"M", "-", "Mn", "-", "Mpi"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"M", "+", "Mn", "-", "Mpi"}], ")"}], " ", 
      RowBox[{"(", 
