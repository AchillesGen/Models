Cell[CellGroupData[{

Cell["Spin 3/2 projection operator as a polarization sum", "Subsection",
 CellChangeTimes->{{3.98322247259264*^9, 
  3.983222482545407*^9}},ExpressionUUID->"5a7bdbdc-5b9e-bc43-9582-\
