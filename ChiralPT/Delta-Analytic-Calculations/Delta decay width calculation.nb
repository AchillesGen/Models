                 RowBox[{"h", " ", "M"}], 
                 RowBox[{"8", "\[Pi]", " ", "fPi"}]], ")"}], "2"], "*", 
              SuperscriptBox["\[Lambda]", "3"], 
              RowBox[{"(", 
