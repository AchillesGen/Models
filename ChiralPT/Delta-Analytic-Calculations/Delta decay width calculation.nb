Cell[CellGroupData[{

Cell[TextData[{
 "Delta decay amplitude for \[CapitalDelta]\[Rule]",
 Cell[BoxData[
  FormBox["\[Pi]N", TraditionalForm]],ExpressionUUID->
  "2fd62cdd-2b85-5d48-a107-f45214914b71"]
}], "Section",
 CellChangeTimes->{{3.9688540026519756`*^9, 3.9688540056734905`*^9}, {
  3.978104585751744*^9, 3.9781046103049603`*^9}, {3.9822876615110416`*^9, 
  3.9822876819282837`*^9}, {3.982987692416254*^9, 3.9829876968788967`*^9}, {
  3.9832116339128532`*^9, 3.983211646370814*^9}, {3.9854659879033375`*^9, 
  3.985465993929859*^9}},ExpressionUUID->"282ce89a-0678-ec4a-8c44-\
bae0f3c8c84f"],

Cell[TextData[{
 "M - mass of the \[CapitalDelta](1232) resonance.\n\[CapitalGamma] - width \
of the \[CapitalDelta](1232) resonance.\ngDGI - the hadronic coupling between \
\[CapitalDelta]N\[Pi]. It is the same thing as the coupling h in \
https://arxiv.org/pdf/nucl-th/0509020\nisospinFactor - It is equal ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"to", " ", 
     SqrtBox[
      FractionBox["1", "3"]]}], ",", " ", 
    SqrtBox[
     FractionBox["2", "3"]], ",", 
    SqrtBox[
     FractionBox["3", "3"]]}], TraditionalForm]],ExpressionUUID->
  "d3f116bb-b36b-6442-ad3c-2284bc0ecfd0"]
}], "Text",
 CellChangeTimes->{{3.9832069336376877`*^9, 3.983206961008774*^9}, {
  3.9832071415468616`*^9, 3.983207189122291*^9}, {3.983207232615298*^9, 
  3.983207317776144*^9}, {3.983213706005308*^9, 3.983213721057177*^9}, {
  3.984737174354228*^9, 
  3.98473717544717*^9}},ExpressionUUID->"f0d7df23-ea45-b748-83dd-\
e285d7d873a2"],

Cell[CellGroupData[{

Cell["\[CapitalDelta] polarization sum", "Subsection",
 CellChangeTimes->{{3.985466136922764*^9, 
  3.985466166114813*^9}},ExpressionUUID->"0a0bae13-e316-d242-a373-\
127941d2ffb0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"P32", "[", 
   RowBox[{"mu_", ",", "nu_", ",", "p1_"}], "]"}], ":=", 
  RowBox[{"-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"GS", "[", "p1", "]"}], "+", "M"}], ")"}], ".", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
        RowBox[{"LorentzIndex", "[", "nu", "]"}]}], "]"}], "-", 
      RowBox[{
       FractionBox["1", "3"], 
       RowBox[{
        RowBox[{"GA", "[", "mu", "]"}], ".", 
        RowBox[{"GA", "[", "nu", "]"}]}]}], "-", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
          RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
          RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}]}], 
       RowBox[{"3", 
        SuperscriptBox["M", "2"]}]], "-", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Pair", "[", 
          RowBox[{
           RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
           RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
         RowBox[{"GA", "[", "nu", "]"}]}], "-", 
        RowBox[{
         RowBox[{"Pair", "[", 
          RowBox[{
           RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
           RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
         RowBox[{"GA", "[", "mu", "]"}]}]}], 
       RowBox[{"3", "M"}]]}], ")"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9854603521311607`*^9, 3.9854603546570377`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"15488912-1866-ff4f-bc97-4f146870abe4"],

Cell["\<\
Based on https://cds.cern.ch/record/1569221/files/arXiv:1308.1668.pdf\
\>", "Text",
 CellChangeTimes->{{3.9854661813632393`*^9, 
  3.9854661829248695`*^9}},ExpressionUUID->"9b13a34e-f085-334b-8287-\
760f07be062c"]
}, Closed]],

Cell[CellGroupData[{

Cell["\[Pi]N\[CapitalDelta] interaction vertex", "Subsection",
 CellChangeTimes->{{3.985466145280054*^9, 
  3.985466160004751*^9}},ExpressionUUID->"3d57095a-fa04-7945-9063-\
ecc743e4c8d8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"pionNucleonDeltaGI", "[", 
     RowBox[{"p1_", ",", "p3_", ",", "mu1_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Beta]1", ",", "\[Gamma]1", ",", "\[Alpha]1"}], "}"}], ",", 
      RowBox[{
       FractionBox[
        RowBox[{"\[ImaginaryI]", " ", "h"}], 
        RowBox[{"fPi", " ", "M"}]], "*", "isospinFactor", "*", 
       RowBox[{"Pair", "[", 
        RowBox[{
         RowBox[{"Momentum", "[", "p1", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Beta]1", "]"}]}], "]"}], 
       RowBox[{"Pair", "[", 
        RowBox[{
         RowBox[{"Momentum", "[", "p3", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Alpha]1", "]"}]}], "]"}], 
       RowBox[{
        RowBox[{"GA", "[", "\[Gamma]1", "]"}], ".", 
        RowBox[{"GA", "[", "5", "]"}]}], "*", 
       RowBox[{"Eps", "[", 
        RowBox[{
         RowBox[{"LorentzIndex", "[", "mu1", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Alpha]1", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Beta]1", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Gamma]1", "]"}]}], "]"}]}]}], 
     "]"}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"index", " ", "3"}], " ", "==", " ", "pion"}], ";", " ", 
     RowBox[{
      RowBox[{"index", " ", "1"}], " ", "==", " ", "Delta"}]}], ",", " ", 
    RowBox[{"isospinFactor", "=", 
     SqrtBox[
      FractionBox["1", "3"]]}], ",", 
    RowBox[{
     RowBox[{
      SqrtBox[
       FractionBox["2", "3"]], " ", "or", " ", "1.", " ", "the", " ", 
      "gDGI"}], " ", "=", " ", 
     RowBox[{"h", " ", "from", " ", "the", " ", "paper"}]}]}], " ", 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.968795250462551*^9, 3.968795309987854*^9}, {
   3.96879539929026*^9, 3.96879550195788*^9}, {3.968795732297863*^9, 
   3.968795738660909*^9}, 3.968795938883351*^9, {3.968795995901713*^9, 
   3.968796128778061*^9}, {3.9687961598206825`*^9, 3.968796177562132*^9}, {
