Cell[CellGroupData[{

Cell["Comparison with the literature", "Section",
 CellChangeTimes->{{3.9854664285693817`*^9, 
  3.9854664345102253`*^9}},ExpressionUUID->"25cf1317-422d-6343-a098-\
f7df62b70ed4"],

Cell["\<\
Pascalutsa decay width is well hidden in this paper \
https://journals.aps.org/prd/pdf/10.1103/PhysRevD.73.034003
Ramirez decay width is https://arxiv.org/pdf/nucl-th/0509020 Eq. B7 \
\>", "Text",
 CellChangeTimes->{{3.985467046784973*^9, 3.985467073797695*^9}, {
  3.9854671205197773`*^9, 
  3.9854671258824844`*^9}},ExpressionUUID->"632e75bd-ad28-de40-ac2b-\
6f42d99c553b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"decayWidth", "[", "\"\<Pascalutsa\>\"", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              FractionBox[
               RowBox[{"4", "\[Pi]"}], "3"], "M", "*", 
              SuperscriptBox[
               RowBox[{"(", 
                FractionBox[
                 RowBox[{"hPascalutsa", " ", "M"}], 
                 RowBox[{"8", "\[Pi]", " ", "fPi"}]], ")"}], "2"], "*", 
              SuperscriptBox["\[Lambda]", "3"], 
              RowBox[{"(", 
               RowBox[{"\[Alpha]", "+", "\[Rho]"}], ")"}]}], ")"}], "/.", 
            RowBox[{"{", 
             RowBox[{"\[Lambda]", "->", 
              SqrtBox[
               RowBox[{
                SuperscriptBox["\[Alpha]", "2"], "-", 
                SuperscriptBox["\[Rho]", "2"]}]]}], "}"}]}], ")"}], "/.", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]", "->", 
            RowBox[{"1", "-", "\[Beta]"}]}], "}"}]}], ")"}], "/.", 
        RowBox[{"{", 
         RowBox[{"\[Beta]", "->", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             SuperscriptBox["\[Rho]", "2"], "+", 
             SuperscriptBox["\[Mu]", "2"]}], ")"}]}]}], "}"}]}], "//", 
       "FullSimplify"}], ")"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Mu]", "->", 
        FractionBox["MPi", "M"]}], ",", 
       RowBox[{"\[Rho]", "->", 
        FractionBox["MN", "M"]}]}], "}"}]}], "//", "Expand"}], "//", 
   "FullSimplify"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"decayWidth", "[", "\"\<Ramirez\>\"", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      SuperscriptBox["hRamirez", "2"], 
      RowBox[{"3", "\[Pi]", " ", 
       SuperscriptBox["fPi", "2"]}]], "*", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"pCOM", "[", 
        RowBox[{"m1", ",", "m2", ",", "m3"}], "]"}], "3"], "M"], 
     RowBox[{"(", 
      RowBox[{"MN", "+", 
       SqrtBox[
        RowBox[{
         SuperscriptBox[
          RowBox[{"pCOM", "[", 
           RowBox[{"m1", ",", "m2", ",", "m3"}], "]"}], "2"], "+", 
         SuperscriptBox["MN", "2"]}]]}], ")"}]}], "//", "Expand"}], "//", 
   "FullSimplify"}]}]}], "Input",
 CellChangeTimes->{{3.983236256274*^9, 3.983236362792015*^9}, {
  3.983236411377043*^9, 3.983236416878927*^9}, {3.985465803548088*^9, 
  3.985465804578773*^9}, {3.985466449836763*^9, 3.9854664874900913`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"d335c027-d860-5149-a5c4-61dbce4b269a"],

Cell["The ratio of their decay width to our", "Text",
 CellChangeTimes->{{3.9854671403276424`*^9, 
  3.9854671473191433`*^9}},ExpressionUUID->"da3041eb-48ed-a247-9ac3-\
cdb8c1579513"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Simplify", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"decayWidth", "[", "test", "]"}], 
      RowBox[{"decayWidth", "[", "\"\<we\>\"", "]"}]], ",", 
     RowBox[{"{", 
      RowBox[{"test", ",", 
       RowBox[{"{", 
        RowBox[{"\"\<Pascalutsa\>\"", ",", "\"\<Ramirez\>\""}], "}"}]}], 
      "}"}]}], "]"}], "]"}], "/.", 
  RowBox[{"{", 
   RowBox[{"isospinFactor", "->", "1"}], "}"}]}]], "Input",
 CellChangeTimes->{{3.98546675909239*^9, 3.985466831450222*^9}, {
  3.985467019123489*^9, 3.9854670238334713`*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"97275203-1180-8e41-9ed2-39c715f3147e"],

Cell[TextData[{
 "Ramirez coupling https://arxiv.org/pdf/nucl-th/0509020\n",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
