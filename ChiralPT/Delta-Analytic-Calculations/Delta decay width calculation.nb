Cell[TextData[{
 "M - mass of the \[CapitalDelta](1232) resonance.\n\[CapitalGamma] - width \
of the \[CapitalDelta](1232) resonance.\ngDGI - the hadronic coupling between \
\[CapitalDelta]N\[Pi]. It is the same thing as the coupling h in \
https://arxiv.org/pdf/nucl-th/0509020\nisospinFactor - It is equal ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"to", " ", 
     SqrtBox[
      FractionBox["1", "3"]]}], ",", " ", 
    SqrtBox[
     FractionBox["2", "3"]], ",", 
    SqrtBox[
     FractionBox["3", "3"]]}], TraditionalForm]],ExpressionUUID->
  "45433b03-d479-0545-b9f4-38d34e8eef23"]
}], "Text",
