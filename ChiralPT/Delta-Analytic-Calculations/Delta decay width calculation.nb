Cell[CellGroupData[{

Cell["Conclusion", "Section",
 CellChangeTimes->{{3.985467171109253*^9, 
  3.985467173558914*^9}},ExpressionUUID->"948fabe9-1d1e-f049-9852-\
d24d215ca30a"],

Cell[TextData[{
 "By looking at the decay width results we see two things.\[LineSeparator]\n\
We fully agree with Pascalutsa because indeed ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["h", "us"], "==", 
    RowBox[{
     FractionBox["1", "2"], 
     SubscriptBox["h", "pascalutsa"]}]}], TraditionalForm]],ExpressionUUID->
  "a36d52af-c2f4-5f43-bdd6-50761938824b"],
 " \[Rule] 1.43 = ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "2"], TraditionalForm]],ExpressionUUID->
  "77a90372-9a2d-564c-bf5a-d6bd07e729ee"],
 " 2.85.\[LineSeparator]\[LineSeparator]To agree with Ramirez we would need ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["h", "us"], "==", 
    RowBox[{"2", 
     SubscriptBox["h", "ramirez"]}]}], TraditionalForm]],ExpressionUUID->
  "4d164494-a462-c64c-acf5-d1ec22464ea0"],
 " which is ",
 StyleBox["numerically",
  FontWeight->"Bold"],
 " true (1.5 = 2 x 0.75), according to table 3 in \
https://arxiv.org/pdf/nucl-th/0509020. However, their coupling in the \
Lagrangian, as written in Eq. 32, is ",
 StyleBox["the same ",
  FontWeight->"Bold"],
 "as ours.\[LineSeparator]",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
