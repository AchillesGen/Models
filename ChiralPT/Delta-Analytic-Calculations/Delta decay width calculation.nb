  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              FractionBox[
               RowBox[{"4", "\[Pi]"}], "3"], "M", "*", 
              SuperscriptBox[
               RowBox[{"(", 
                FractionBox[
                 RowBox[{"h", " ", "M"}], 
                 RowBox[{"8", "\[Pi]", " ", "fPi"}]], ")"}], "2"], "*", 
              SuperscriptBox["\[Lambda]", "3"], 
              RowBox[{"(", 
               RowBox[{"\[Alpha]", "+", "\[Rho]"}], ")"}]}], ")"}], "/.", 
            RowBox[{"{", 
             RowBox[{"\[Lambda]", "->", 
              SqrtBox[
               RowBox[{
                SuperscriptBox["\[Alpha]", "2"], "-", 
                SuperscriptBox["\[Rho]", "2"]}]]}], "}"}]}], ")"}], "/.", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]", "->", 
            RowBox[{"1", "-", "\[Beta]"}]}], "}"}]}], ")"}], "/.", 
        RowBox[{"{", 
         RowBox[{"\[Beta]", "->", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             SuperscriptBox["\[Rho]", "2"], "+", 
             SuperscriptBox["\[Mu]", "2"]}], ")"}]}]}], "}"}]}], "//", 
       "FullSimplify"}], ")"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Mu]", "->", 
        FractionBox["MPi", "M"]}], ",", 
       RowBox[{"\[Rho]", "->", 
        FractionBox["MN", "M"]}]}], "}"}]}], "//", "Expand"}], "//", 
   "FullSimplify"}]}]], "Input",
