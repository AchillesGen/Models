Cell[CellGroupData[{

Cell["Spin 3/2 projection operator as a polarization sum", "Subsection",
 CellChangeTimes->{{3.98322247259264*^9, 
  3.983222482545407*^9}},ExpressionUUID->"5a7bdbdc-5b9e-bc43-9582-\
8427ce69e8f6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"P32", "[", 
   RowBox[{"mu_", ",", "nu_", ",", "p1_"}], "]"}], ":=", 
  RowBox[{"-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"GS", "[", "p1", "]"}], "+", "M"}], ")"}], ".", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
        RowBox[{"LorentzIndex", "[", "nu", "]"}]}], "]"}], "-", 
      RowBox[{
       FractionBox["1", "3"], 
       RowBox[{
        RowBox[{"GA", "[", "mu", "]"}], ".", 
        RowBox[{"GA", "[", "nu", "]"}]}]}], "-", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
          RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
          RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}]}], 
       RowBox[{"3", 
        SuperscriptBox["M", "2"]}]], "-", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Pair", "[", 
          RowBox[{
           RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
           RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
         RowBox[{"GA", "[", "nu", "]"}]}], "-", 
        RowBox[{
         RowBox[{"Pair", "[", 
          RowBox[{
           RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
           RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
         RowBox[{"GA", "[", "mu", "]"}]}]}], 
       RowBox[{"3", "M"}]]}], ")"}]}]}]}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"4d9fccd0-c626-2c46-8c1d-501f58b22d83"],

Cell[BoxData[
 RowBox[{
  RowBox[{"P32", "[", 
   RowBox[{"mu_", ",", "nu_", ",", "p1_"}], "]"}], ":=", 
  RowBox[{"-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"GS", "[", "p1", "]"}], "+", "M"}], ")"}], ".", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
        RowBox[{"LorentzIndex", "[", "nu", "]"}]}], "]"}], "-", 
      RowBox[{
       FractionBox["1", "3"], 
       RowBox[{
        RowBox[{"GA", "[", "mu", "]"}], ".", 
        RowBox[{"GA", "[", "nu", "]"}]}]}], "-", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
          RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
          RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}]}], 
       RowBox[{"3", 
        SuperscriptBox["M", "2"]}]], "-", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Pair", "[", 
          RowBox[{
           RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
           RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
         RowBox[{"GA", "[", "nu", "]"}]}], "-", 
        RowBox[{
         RowBox[{"Pair", "[", 
          RowBox[{
           RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
           RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
         RowBox[{"GA", "[", "mu", "]"}]}]}], 
       RowBox[{"3", "M"}]]}], ")"}]}]}]}]], "Input",
 CellChangeTimes->{{3.983222489120554*^9, 3.983222697507189*^9}, {
  3.983222728813267*^9, 3.983222776179756*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"0759eb03-b713-8449-b9dc-e3da873470c4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"P32", "[", 
   RowBox[{"mu_", ",", "nu_", ",", "p1_"}], "]"}], ":=", 
  RowBox[{"-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"GS", "[", "p1", "]"}], "+", "M"}], ")"}], ".", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
        RowBox[{"LorentzIndex", "[", "nu", "]"}]}], "]"}], "-", 
      RowBox[{
