       RowBox[{"Eps", "[", 
        RowBox[{
         RowBox[{"LorentzIndex", "[", "mu1", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Alpha]", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Beta]", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Gamma]", "]"}]}], "]"}], 
