Cell[CellGroupData[{

Cell["Kinematic variables", "Subsection",
 CellChangeTimes->{{3.9854661175980473`*^9, 
  3.9854661256196957`*^9}},ExpressionUUID->"861f98c8-d8e7-ff4a-84a0-\
ebaf8ca4eeee"],

Cell["The decay is described with momenta p1 \[Rule] p3+p2.", "Text",
 CellChangeTimes->{{3.983211726430092*^9, 3.983211776984926*^9}, {
  3.9832221573988247`*^9, 3.98322218461774*^9}, {3.9854660952410126`*^9, 
  3.985466095976471*^9}},ExpressionUUID->"f1263fcb-be76-c349-aa1f-\
56324fcb9679"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"p1", ",", "p1"}], "]"}], "=", 
   SuperscriptBox["m1", "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"p2", ",", "p2"}], "]"}], "=", 
   SuperscriptBox["m2", "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"p3", ",", "p3"}], "]"}], "=", 
   SuperscriptBox["m3", "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"p2", ",", "p3"}], "]"}], "=", 
   FractionBox[
    RowBox[{
     SuperscriptBox["m1", "2"], "-", 
     SuperscriptBox["m2", "2"], "-", 
     SuperscriptBox["m3", "2"]}], "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"p1", ",", "p2"}], "]"}], "=", 
   FractionBox[
    RowBox[{
     SuperscriptBox["m1", "2"], "+", 
     SuperscriptBox["m2", "2"], "-", 
     SuperscriptBox["m3", "2"]}], "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ScalarProduct", "[", 
    RowBox[{"p3", ",", "p1"}], "]"}], "=", 
   FractionBox[
    RowBox[{
     SuperscriptBox["m1", "2"], "+", 
     SuperscriptBox["m3", "2"], "-", 
     SuperscriptBox["m2", "2"]}], "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"$Assumptions", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"m1", ">", 
     RowBox[{"m2", "+", "m3"}]}], ",", 
    RowBox[{"m1", ">", "0"}], ",", 
    RowBox[{"m2", ">", "0"}], ",", 
    RowBox[{"m3", ">", "0"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m1", "=", "M"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m2", "=", "MN"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m3", "=", "MPi"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pCOM", "[", 
    RowBox[{"m1_", ",", "m2_", ",", "m3_"}], "]"}], ":=", 
   FractionBox[
    SqrtBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{"m1", "+", "m2", "+", "m3"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"m1", "+", "m2", "-", "m3"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"m1", "-", "m2", "+", "m3"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"m1", "-", "m2", "-", "m3"}], ")"}]}]], 
    RowBox[{"2", "m1"}]]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9832232858265686`*^9, 3.983223294676031*^9}, {
  3.9832233876730976`*^9, 3.98322339893776*^9}, {3.983223453073673*^9, 
  3.983223482916603*^9}, {3.983223536333397*^9, 3.983223644377066*^9}, {
  3.983223742394663*^9, 3.9832237993055096`*^9}, {3.983223920320791*^9, 
  3.983223928719929*^9}, {3.98322535386482*^9, 3.983225369937992*^9}, {
  3.983236385681036*^9, 3.983236394375315*^9}, {3.9854661102715034`*^9, 
  3.9854661104625473`*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"fe3934ba-db68-fb4f-856c-0a46f962d321"]
}, Closed]],

