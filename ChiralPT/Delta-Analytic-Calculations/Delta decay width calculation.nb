Cell[BoxData[
 RowBox[{
  RowBox[{"P32", "[", 
   RowBox[{"mu_", ",", "nu_", ",", "p1_"}], "]"}], ":=", 
  RowBox[{"-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"GS", "[", "p1", "]"}], "+", "M"}], ")"}], ".", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pair", "[", 
       RowBox[{
        RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
        RowBox[{"LorentzIndex", "[", "nu", "]"}]}], "]"}], "-", 
      RowBox[{
       FractionBox["1", "3"], 
       RowBox[{
        RowBox[{"GA", "[", "mu", "]"}], ".", 
        RowBox[{"GA", "[", "nu", "]"}]}]}], "-", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
          RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
        RowBox[{"Pair", "[", 
         RowBox[{
          RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
          RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}]}], 
       RowBox[{"3", 
        SuperscriptBox["M", "2"]}]], "-", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Pair", "[", 
          RowBox[{
           RowBox[{"LorentzIndex", "[", "mu", "]"}], ",", 
           RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
         RowBox[{"GA", "[", "nu", "]"}]}], "-", 
        RowBox[{
         RowBox[{"Pair", "[", 
          RowBox[{
           RowBox[{"LorentzIndex", "[", "nu", "]"}], ",", 
           RowBox[{"Momentum", "[", "p1", "]"}]}], "]"}], 
         RowBox[{"GA", "[", "mu", "]"}]}]}], 
       RowBox[{"3", "M"}]]}], ")"}]}]}]}]], "Input",
 CellLabel->
  "In[195]:=",ExpressionUUID->"4d9fccd0-c626-2c46-8c1d-501f58b22d83"],

