Cell[BoxData[
 RowBox[{
  RowBox[{"T", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       SqrtBox["6"]], 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", 
           SqrtBox["3"]}], ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"-", "1"}], ",", "0", ",", 
          SqrtBox["3"]}], "}"}]}], "\[IndentingNewLine]", "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "\[ImaginaryI]"}], 
       SqrtBox["6"]], 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          SqrtBox["3"], ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1", ",", "0", ",", 
          SqrtBox["3"]}], "}"}]}], "\[IndentingNewLine]", "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      SqrtBox[
       FractionBox["2", "3"]], 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}]}], 
       "\[IndentingNewLine]", "}"}]}]}], "\[IndentingNewLine]", "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.985468661389618*^9, 3.9854688211615314`*^9}, 
   3.9854752681689014`*^9},ExpressionUUID->"248532be-93ba-2e44-9a86-\
cc739459e16a"],

Cell[BoxData[
 RowBox[{"lag", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", "h"}], 
      RowBox[{"2", "fPi", " ", "M"}]], 
     RowBox[{"(", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[Pi]", "a"], 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            OverscriptBox["p", "_"], ",", 
            OverscriptBox["n", "_"]}], "}"}], ".", 
          RowBox[{"T", "[", 
           RowBox[{"[", "a", "]"}], "]"}], ".", 
          RowBox[{"{", 
           RowBox[{
            SubscriptBox["\[CapitalDelta]", "\"\<++\>\""], ",", 
            SubscriptBox["\[CapitalDelta]", "\"\<+\>\""], ",", 
            SubscriptBox["\[CapitalDelta]", "\"\<0\>\""], ",", 
            SubscriptBox["\[CapitalDelta]", "\"\<-\>\""]}], "}"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"a", ",", "1", ",", "3"}], "}"}]}], "]"}], ")"}]}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Pi]", "1"], "->", 
       RowBox[{
        FractionBox["1", 
         SqrtBox["2"]], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[Pi]", "\"\<+\>\""], "+", 
          SuperscriptBox["\[Pi]", "\"\<-\>\""]}], ")"}]}]}], ",", 
      RowBox[{
       SubscriptBox["\[Pi]", "2"], "->", 
       RowBox[{
        FractionBox["\[ImaginaryI]", 
         SqrtBox["2"]], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[Pi]", "\"\<+\>\""], "-", 
          SuperscriptBox["\[Pi]", "\"\<-\>\""]}], ")"}]}]}], ",", 
      RowBox[{
       SubscriptBox["\[Pi]", "3"], "->", 
       SuperscriptBox["\[Pi]", "\"\<0\>\""]}]}], "}"}]}], "//", 
   "Expand"}]}]], "Input",
 CellChangeTimes->{{3.9854688333879566`*^9, 3.9854690884187737`*^9}, {
   3.9854693452915916`*^9, 3.985469353999872*^9}, {3.985469392067629*^9, 
   3.98546945358445*^9}, {3.9854694905524254`*^9, 3.9854695023280067`*^9}, {
   3.9854696554032936`*^9, 3.98546966591177*^9}, 
   3.98547527327742*^9},ExpressionUUID->"ca41e0c4-5114-b44d-822d-\
7a5ad322aace"],

Cell[TextData[{
 "Isolating the highest isospin transition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalDelta]", "++"], "->", 
    SuperscriptBox["p\[Pi]", "+"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f405d6b5-eebf-5947-9c90-d229bb477219"],
 " we see that, indeed ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["h", "us"], "==", 
    FractionBox[
     SubscriptBox["h", "pascalutsa"], "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "913f6e66-25be-5344-9e77-7f0326f81f3f"],
 "."
}], "Text",
