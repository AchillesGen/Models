Cell[BoxData[{
 RowBox[{
  RowBox[{"pBefore", "=", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], "-", 
      RowBox[{"2", "s", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          SubscriptBox["m", "1"], "2"], "+", 
         SuperscriptBox[
          SubscriptBox["m", "2"], "2"]}], ")"}]}], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          SubscriptBox["m", "1"], "2"], "-", 
         SuperscriptBox[
          SubscriptBox["m", "2"], "2"]}], ")"}], "2"]}], 
     RowBox[{"4", "s"}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pAfter", "=", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], "-", 
      RowBox[{"2", "s", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          SubscriptBox["m", "3"], "2"], "+", 
         SuperscriptBox[
          SubscriptBox["m", "4"], "2"]}], ")"}]}], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          SubscriptBox["m", "3"], "2"], "-", 
         SuperscriptBox[
          SubscriptBox["m", "4"], "2"]}], ")"}], "2"]}], 
     RowBox[{"4", "s"}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"convertToAngleGeneral", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"t", "->", 
       RowBox[{
        SuperscriptBox[
         SubscriptBox["m", "1"], "2"], "+", 
        SuperscriptBox[
         SubscriptBox["m", "3"], "2"], "-", 
        RowBox[{"2", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["pBefore", "2"], "+", 
           SuperscriptBox[
            SubscriptBox["m", "1"], "2"]}]], 
         SqrtBox[
          RowBox[{
           SuperscriptBox["pAfter", "2"], "+", 
           SuperscriptBox[
            SubscriptBox["m", "1"], "2"]}]]}], "+", 
        RowBox[{"2", "pBefore", "*", "pAfter", " ", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]}], ",", 
      RowBox[{"u", "->", 
       RowBox[{
        SuperscriptBox[
         SubscriptBox["m", "1"], "2"], "+", 
        SuperscriptBox[
         SubscriptBox["m", "2"], "2"], "+", 
        SuperscriptBox[
         SubscriptBox["m", "3"], "2"], "+", 
        SuperscriptBox[
         SubscriptBox["m", "4"], "2"], "-", "s", "-", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox[
           SubscriptBox["m", "1"], "2"], "+", 
          SuperscriptBox[
           SubscriptBox["m", "3"], "2"], "-", 
          RowBox[{"2", 
           SqrtBox[
            RowBox[{
             SuperscriptBox["pBefore", "2"], "+", 
             SuperscriptBox[
              SubscriptBox["m", "1"], "2"]}]], 
           SqrtBox[
            RowBox[{
             SuperscriptBox["pAfter", "2"], "+", 
             SuperscriptBox[
              SubscriptBox["m", "1"], "2"]}]]}], "+", 
          RowBox[{"2", "pBefore", "*", "pAfter", " ", 
           RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ")"}]}]}]}], "}"}]}], 
   ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"convertToAngleGeneral", "/.", 
