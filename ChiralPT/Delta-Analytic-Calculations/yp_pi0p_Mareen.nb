Cell[TextData[{
 "The Mandelstam variable t is very nice for elastic scattering. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[Element]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "4"}], 
       SuperscriptBox[
        SubscriptBox["p", "com"], "2"]}], ",", "0"}]}]}], TraditionalForm]],
  ExpressionUUID->"027a3c9b-1951-ae41-8d0d-bdd12247c90c"],
 ") where"
}], "Text",
 CellChangeTimes->{{3.978096677073334*^9, 3.9780967215854855`*^9}, {
  3.9780968868767204`*^9, 
  3.9780968868767204`*^9}},ExpressionUUID->"d5009407-65df-c547-a575-\
bf63d5db2011"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pCOM", "[", 
    RowBox[{"s_", ",", "m1_", ",", "m2_"}], "]"}], ":=", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], "-", 
      RowBox[{"2", "s", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["m1", "2"], "+", 
         SuperscriptBox["m2", "2"]}], ")"}]}], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["m1", "2"], "-", 
         SuperscriptBox["m2", "2"]}], ")"}], "2"]}], 
     RowBox[{"4", "s"}]]]}], ";"}]], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"9185b7ea-bb76-9646-922b-2a0b703c8f9e"],

