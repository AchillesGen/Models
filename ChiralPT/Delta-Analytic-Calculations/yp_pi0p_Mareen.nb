Cell[BoxData[{
 RowBox[{
  RowBox[{"MR", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "1232", ",", "1440", ",", "1520", ",", "1535", ",", "1620", ",", "1650", 
