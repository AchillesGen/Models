Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"pionNucleonDeltaGI", "[", 
     RowBox[{"p3_", ",", "p1_", ",", "mu1_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "}"}], ",", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       FractionBox["gDGI", 
        RowBox[{"fPi", " ", "M"}]], "*", 
       SqrtBox[
        FractionBox["2", "3"]], "*", 
       RowBox[{"Eps", "[", 
        RowBox[{
         RowBox[{"LorentzIndex", "[", "mu1", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Alpha]", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Beta]", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Gamma]", "]"}]}], "]"}], 
       RowBox[{
        RowBox[{"GA", "[", "\[Gamma]", "]"}], ".", 
        RowBox[{"GA", "[", "5", "]"}]}], 
       RowBox[{"Pair", "[", 
        RowBox[{
         RowBox[{"Momentum", "[", "p3", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Alpha]", "]"}]}], "]"}], 
       RowBox[{"Pair", "[", 
        RowBox[{
         RowBox[{"Momentum", "[", "p1", "]"}], ",", 
         RowBox[{"LorentzIndex", "[", "\[Beta]", "]"}]}], "]"}]}]}], "]"}]}], 
   ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"index", " ", "3"}], " ", "==", " ", "pion"}], ";", " ", 
     RowBox[{
      RowBox[{"index", " ", "1"}], " ", "==", " ", "Delta"}]}], ",", " ", 
    RowBox[{"isospinFactor", "=", 
     SqrtBox[
      FractionBox["2", "3"]]}], ",", " ", 
    RowBox[{
     RowBox[{"the", " ", "gDGI"}], " ", "=", " ", 
     RowBox[{"h", " ", "from", " ", "the", " ", "paper"}]}]}], " ", 
   "*)"}]}]], "Input",
