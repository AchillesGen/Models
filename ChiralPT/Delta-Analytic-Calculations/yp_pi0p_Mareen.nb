Cell[TextData[{
 "Datasets X and Y correspond to neutral pion resonant production as a \
function of photon energy ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      SubscriptBox["\[Sigma]", "tot"], "resonant"], "(", 
     RowBox[{"\[Gamma]p", "->", 
      RowBox[{
       SuperscriptBox["\[Pi]", "0"], "p"}]}], ")"}], 
    RowBox[{
     RowBox[{"(", 
      SubscriptBox["E", "\[Gamma]"], ")"}], "."}]}], TraditionalForm]],
  ExpressionUUID->"be5e93e6-e908-3b4e-905c-8d6769092e4e"],
 "\nThe dataset X is the low energy data that ",
 ButtonBox["covers the first \[CapitalDelta](1232) resonance",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.hepdata.net/record/ins1380445"], None},
  ButtonNote->"https://www.hepdata.net/record/ins1380445"],
 ". It is depicted by black points on the plot.\nThe dataset Y is the high \
energy data ",
 ButtonBox["covering other resonances",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://clas.sinp.msu.ru/cgi-bin/jlab/msm.cgi?eid=100&mid=1&data=on"]\
, None},
  ButtonNote->
   "https://clas.sinp.msu.ru/cgi-bin/jlab/msm.cgi?eid=100&mid=1&data=on"],
 ". It is depicted by red points on the plot."
}], "Text",
 CellChangeTimes->{{3.982984693290348*^9, 3.982984735843006*^9}, {
  3.9829858287646103`*^9, 3.982985891489216*^9}, {3.982986176736693*^9, 
