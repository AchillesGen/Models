    SubscriptBox["E", "\[Gamma]"], " ", "spectrum"}], " ", "*)"}]}]}], "Input",\

 CellChangeTimes->{{3.982808474479294*^9, 3.9828085709860687`*^9}, {
  3.982809941180885*^9, 3.982809972637863*^9}, {3.982982433821169*^9, 
  3.982982459814392*^9}, {3.982984780102101*^9, 3.982984801703432*^9}, {
  3.987774551625167*^9, 3.9877745533211117`*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"094ecfa8-bf70-4148-8f7c-7ab1cf6b51cf"],

Cell[TextData[{
 "What different variables mean:\[LineSeparator]M - mass of Delta\
\[LineSeparator]MN - mass of Nucleon\[LineSeparator]\[CapitalGamma] - Delta\
\[CloseCurlyQuote]s decay width (I had to set it to some value to relax the s \
channel divergence) \[CapitalGamma] = 117 MeV\[LineSeparator]fPi - ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "\[Pi]"], " ", "=", " ", 
    RowBox[{"93", "MeV"}]}], TraditionalForm]],ExpressionUUID->
  "dfca6d9a-ab04-214c-a4e9-c06d18a47a87"],
 "\ngD - the coupling from The Book, Eq. 4.202. Should be about gD = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["3", "5"], 
    SqrtBox["2"], "gA"}], TraditionalForm]],ExpressionUUID->
  "51e86632-551d-8947-9fed-7f6e86c7edd3"],
 " = 1.07\[LineSeparator]gDGI - so far unknown in value. Some reasonable \
values I found are ~0.17 looking just by eye\[LineSeparator]\nAccording to \
https://www.hepdata.net/record/ins44234, the charged pion nucleon elastic \
cross section is 16mb at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"energies", " ", 
    SqrtBox["s"]}], TraditionalForm]],ExpressionUUID->
  "0e37a08a-0f20-f74c-a3c4-c9d0d075f09d"],
 "~1.75GeV This lead me to estimate gDGI~0.2045 and gD~0.4\[LineSeparator]\
\[LineSeparator]The GI coupling does seem to increase the total cross section \
more quickly (cross section blows up ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"with", " ", "W"}], "=", 
    RowBox[{
     SqrtBox["s"], "."}]}], TraditionalForm]],ExpressionUUID->
  "78cec0bb-830c-684b-9103-612466473881"],
 ")"
}], "Text",
 CellChangeTimes->{{3.978063906177332*^9, 3.978064249737532*^9}, {
  3.9780642941952667`*^9, 3.978064419439481*^9}, {3.978064500808668*^9, 
  3.9780645015348473`*^9}, {3.978103519430549*^9, 3.9781036289555855`*^9}, {
  3.978103737617405*^9, 
  3.978103802989292*^9}},ExpressionUUID->"999038e2-7bd8-5a43-a685-\
649e8911ed93"],

Cell["To have the cross section match at resonance, we compute", "Text",
 CellChangeTimes->{{3.978098392281706*^9, 3.9780984112699623`*^9}, {
  3.978098572287216*^9, 
  3.9780985732236023`*^9}},ExpressionUUID->"aca80150-a88f-8740-9ac7-\
5757bbf03b9a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FormFactor", "[", 
    RowBox[{"s_", ",", "mRes_", ",", "\[CapitalLambda]_"}], "]"}], ":=", 
   FractionBox["1", 
    RowBox[{"1", "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"s", "-", 
         SuperscriptBox["mRes", "2"]}], ")"}], "2"], "/", 
      SuperscriptBox["\[CapitalLambda]", "4"]}]}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.982812605132007*^9, 3.982812658318945*^9}},
 CellLabel->"In[42]:=",ExpressionUUID->"4ba551d5-c343-4f4c-9df5-ec6bdd9d1449"],

