Cell[TextData[{
 "The Mandelstam variable t is very nice for elastic scattering. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[Element]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "4"}], 
       SuperscriptBox[
        SubscriptBox["p", "com"], "2"]}], ",", "0"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4aa3fd70-27de-4f46-9d8d-e9bea80641e0"],
 ") where"
}], "Text",
