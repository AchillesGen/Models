Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pCOM", "[", 
    RowBox[{"s_", ",", "m1_", ",", "m2_"}], "]"}], ":=", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], "-", 
      RowBox[{"2", "s", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["m1", "2"], "+", 
         SuperscriptBox["m2", "2"]}], ")"}]}], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["m1", "2"], "-", 
         SuperscriptBox["m2", "2"]}], ")"}], "2"]}], 
     RowBox[{"4", "s"}]]]}], ";"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"9185b7ea-bb76-9646-922b-2a0b703c8f9e"],

Cell[TextData[{
 "The differential cross section is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["d\[Sigma]", "dt"], "=", 
    FractionBox[
     RowBox[{"|", "\[ScriptCapitalM]", 
      SuperscriptBox["|", "2"]}], 
     RowBox[{"64", "\[Pi]", " ", "s", " ", 
      SuperscriptBox[
       SubscriptBox["p", "com"], "2"]}]]}], TraditionalForm]],ExpressionUUID->
  "e9779c3f-0c54-b641-9dca-4c449baea7b9"]
}], "Text",
